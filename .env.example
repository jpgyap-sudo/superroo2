# SuperRoo — Environment Variables
# Copy this file to .env and fill in your values
# docker compose will read this file automatically

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot Token (for Telegram control plane)
# Get from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (for receiving bot notifications)
# Get from https://t.me/userinfobot
BOSS_TELEGRAM_CHAT_ID=your_chat_id_here

# ── API Keys ──────────────────────────────────────────────────────────────────

# At least one LLM provider API key is required for AI features
# DeepSeek (recommended — cheapest)
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# OpenAI (fallback)
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (fallback)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# OpenRouter (fallback)
# OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# ── PostgreSQL — Central Brain Memory Store ────────────────────────────────────

POSTGRES_USER=superroo
POSTGRES_PASSWORD=superroo
POSTGRES_DB=superroo_brain

# ── Redis — Queue Backend ──────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379

# ── Ollama — Local Embeddings & AI ─────────────────────────────────────────────

# URL to Ollama running on host machine (not in Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model used for embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text
# Model used for chat/classifier
OLLAMA_CHAT_MODEL=hermes3:latest

# ── Optional — Docker Deployment ───────────────────────────────────────────────

# Set to "production" for production deployment
NODE_ENV=development
# SuperRoo API URL (used by dashboard and mini-ide)
SUPERROO_API_URL=http://localhost:8787
# Dashboard URL (used by mini-ide for proxying)
DASHBOARD_API_URL=http://superroo-api:8787

# ── VPS Deployment (Tailscale) ─────────────────────────────────────────────────

# Tailscale IP of your VPS (DO NOT use public IP)
SUPERROO_VPS_IP=100.64.175.88
# SSH user for VPS deployments
SSH_USER=root
# Path to SuperRoo on VPS
REMOTE_PROJECT_PATH=/opt/superroo2

# ── Optional Features ──────────────────────────────────────────────────────────

# GitHub token for PR creation and code search
# GITHUB_TOKEN=ghp_your_token_here
# Secret vault encryption key (generate with: openssl rand -hex 32)
# SUPERROO_VAULT_KEY=your_64_hex_chars_here
