# =============================================================================
# SuperRoo — Optimized Ollama Configuration for 64GB RAM Systems
# =============================================================================

# --- CPU Parallelism ---
# Use all available cores for parallel processing (adjust for your CPU core count)
OLLAMA_NUM_THREADS=16

# --- Memory Management ---
# Maximum VRAM for model loading (in GB) - keep multiple models in RAM
# With 64GB RAM, allocate up to 48GB for models (leaves 16GB for OS/system)
OLLAMA_MAX_LOADED_MODELS=5

# --- Context Length ---
# Maximum context window (in tokens) - increase for long conversations
# Default is 8192, max supported varies by model (up to 128K for some)
OLLAMA_CONTEXT_LENGTH=65536

# --- Flash Attention ---
# Enable flash attention for faster inference (requires GPU with compute capability >= 8.0)
OLLAMA_FLASH_ATTENTION=1

# --- KV Cache Quantization ---
# Use quantized KV cache to reduce memory usage while maintaining speed
OLLAMA_KV_CACHE_QUANTIZATION=8bit

# --- GPU Offloading (if GPU available) ---
# Enable GPU offloading for compute-intensive operations
OLLAMA_GPU=1

# --- NUMA Optimization ---
# Bind threads to CPU cores for better NUMA locality
OLLAMA_NUMA=1

# --- Batch Processing ---
# Larger batch sizes for parallel prompt processing
OLLAMA_BATCH_SIZE=512
OLLAMA_BATCH_TIMEOUT=10ms

# --- Model Unloading ---
# Keep models loaded longer to avoid re-loading overhead
OLLAMA_UNLOAD_UNUSED_MODELS_AFTER=24h

# --- Concurrent Requests ---
# Number of concurrent requests to process
OLLAMA_MAX_QUEUE=512

# --- Keep-Alive ---
# Keep model in memory for extended periods
OLLAMA_KEEP_ALIVE=1h

# --- Debugging (optional) ---
# OLLAMA_LOG_LEVEL=debug
# OLLAMA_DEBUG=1