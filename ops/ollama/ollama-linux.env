# =============================================================================
# SuperRoo — Model Context and Batch Optimization Scripts
# =============================================================================

# --- Environment Variables (Linux/macOS) ---
# Add to ~/.bashrc or ~/.zshrc
export OLLAMA_NUM_THREADS=16
export OLLAMA_MAX_LOADED_MODELS=5
export OLLAMA_CONTEXT_LENGTH=65536
export OLLAMA_FLASH_ATTENTION=1
export OLLAMA_KV_CACHE_QUANTIZATION=8bit
export OLLAMA_GPU=1
export OLLAMA_NUMA=1
export OLLAMA_BATCH_SIZE=512
export OLLAMA_MAX_QUEUE=512
export OLLAMA_KEEP_ALIVE=1h
export OLLAMA_UNLOAD_UNUSED_MODELS_AFTER=24h