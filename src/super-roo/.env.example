# SuperRoo Daemon Environment Variables
# Copy this file to /etc/superroo/superroo.env and fill in real values.

# ── Daemon HTTP API ──
SUPERROO_DAEMON_HOST=127.0.0.1
SUPERROO_DAEMON_PORT=3417
SUPERROO_DAEMON_TOKEN=change-this-to-a-long-random-token

# ── Workspace & State ──
SUPERROO_WORKSPACE_ROOT=/opt/superroo
SUPERROO_DB_PATH=/var/lib/superroo/superroo.sqlite

# ── Safety ──
# OFF | SAFE | AUTO | FULL_AUTONOMOUS
SUPERROO_SAFETY_MODE=SAFE
SUPERROO_SELF_IMPROVE=false

# ── Optional Features ──
SUPERROO_CRAWLER_ENABLED=false
SUPERROO_IDLE_SLEEP_MS=1000

# ── Deploy (Phase 5) ──
GITHUB_TOKEN=
SUPERROO_REPO_OWNER=
SUPERROO_REPO_NAME=
SUPERROO_VPS_HOST=
SUPERROO_VPS_USER=
SUPERROO_VPS_DEPLOY_PATH=/opt/superroo
SUPERROO_VPS_SSH_KEY_PATH=
SUPERROO_HEALTH_URL=

# ── Telegram Bridge (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
