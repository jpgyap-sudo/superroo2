# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Memory (persistent data, not in image)
memory/*.json

# Large files
*.zip
*.tar.gz
*.tgz
