# Git
.git
.gitattributes
.gitignore
.git-blame-ignore-revs

# Node
node_modules
.pnpm-store

# Build outputs
dist
out
bin
.vite-port
.turbo
*.vsix

# IDE
.vscode
.idea
*.swp
