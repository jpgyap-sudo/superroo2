#!/bin/sh
#
# Global post-commit hook for SuperRoo Cross-Project Learning Layer
#
# Installed by: tools/install-global-hook.mjs
# Installed to: ~/.superroo/git-hooks/post-commit
#
# Auto-extracts lessons from ANY git repo and stores them
# in the Central Brain via superroo-learn.
#
# This is non-blocking — runs in background so git commit stays fast.

# Only run if superroo-learn is available
if ! command -v node >/dev/null 2>&1; then
  exit 0
fi

SUPERROO_LEARN="$HOME/.superroo/bin/superroo-learn"
if [ ! -f "$SUPERROO_LEARN" ]; then
  # Try finding it relative to the superroo2 repo
  SUPERROO_LEARN=""
  for dir in "$HOME/superroo/superroo2" "$HOME/projects/superroo2" "$HOME/code/superroo2"; do
    if [ -f "$dir/tools/superroo-learn.mjs" ]; then
      SUPERROO_LEARN="node $dir/tools/superroo-learn.mjs"
      break
    fi
  done
  if [ -z "$SUPERROO_LEARN" ]; then
    exit 0
  fi
fi

# Get commit info
COMMIT_SHA=$(git rev-parse HEAD 2>/dev/null)
COMMIT_MSG=$(git log -1 --pretty=%B 2>/dev/null)
COMMIT_AUTHOR=$(git log -1 --pretty=%an 2>/dev/null)
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null | tr '\n' ',')

# Check if commit looks lesson-worthy
if echo "$COMMIT_MSG" | grep -qiE "(fix|bug|lesson|learned|workaround|solution|issue|error|crash|race|leak|performance|optimize|refactor|breaking)"; then
  # Run in background — don't slow down git commit
  if [ -n "$SUPERROO_LEARN" ]; then
    if echo "$SUPERROO_LEARN" | grep -q "^node "; then
      eval "$SUPERROO_LEARN extract-commit \"$COMMIT_SHA\" \"$COMMIT_MSG\" \"$COMMIT_AUTHOR\" \"$FILES_CHANGED\"" >/dev/null 2>&1 &
    else
      node "$SUPERROO_LEARN" extract-commit "$COMMIT_SHA" "$COMMIT_MSG" "$COMMIT_AUTHOR" "$FILES_CHANGED" >/dev/null 2>&1 &
    fi
  fi
fi

exit 0
