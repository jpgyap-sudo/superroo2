{
	"id": "homeu-pitchboard-agent",
	"name": "HomeU Pitchboard Agent",
	"category": "homeu-sales",
	"description": "Creates Canva-style luxury pitchboards using exact Shopify product data and image URLs.",
	"version": "1.0.0",
	"enabled": true,
	"modelPolicy": { "preferred": "gpt-5.5", "fallbacks": ["claude-sonnet"], "maxTokens": 5000 },
	"skills": ["skills/csv-product-validation.md", "skills/pitchboard-layout.md"],
	"workflows": ["workflows/csv-to-pitchboard.md"],
	"resources": ["resources/pitchboard-style-guide.md"],
	"memory": { "enabled": true, "scope": "agent" },
	"outputs": "outputs/",
	"safety": {
		"requiresApproval": false,
		"canEditFiles": true,
		"canPublish": false,
		"canDeploy": false,
		"blockedCommands": ["rm -rf /", ".env"],
		"approvalTriggers": ["publish", "deploy"]
	},
	"runtime": { "sandbox": true, "timeoutSeconds": 300, "maxRetries": 2 }
}
