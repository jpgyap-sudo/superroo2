{
	"commandPatterns": [
		"^rm\\s+-rf\\s+/\\s*$",
		"^shutdown\\s",
		"^reboot\\s",
		"^halt\\s",
		"^poweroff\\s",
		"^mkfs\\.",
		"^dd\\s+if=",
		"^:(){ :\\|:& };:",
		"^>\\s*/dev/sda",
		"^mv\\s+/\\s+/dev/null",
		"^wget\\s+.*\\|\\s*bash",
		"^curl\\s+.*\\|\\s*bash",
		"^chmod\\s+-R\\s+777\\s+/",
		"^chown\\s+-R\\s+.*\\s+/$"
	],
	"sqlPatterns": [
		"DROP\\s+DATABASE",
		"DROP\\s+TABLE\\s+\\w+\\s*;\\s*$",
		"TRUNCATE\\s+TABLE",
		"DELETE\\s+FROM\\s+\\w+\\s*;\\s*$",
		"ALTER\\s+.*\\s+DROP\\s+",
		"GRANT\\s+ALL\\s+PRIVILEGES",
		"EXEC\\s+sp_",
		"xp_cmdshell",
		"pg_sleep",
		"BENCHMARK\\s*\\("
	],
	"pathPatterns": [
		"\\.env$",
		"\\.env\\.\\w+$",
		"authorized_keys$",
		"id_rsa$",
		"id_ed25519$",
		"\\.pem$",
		"shadow$",
		"passwd$",
		"sudoers$",
		"\\.kube/config$",
		"credentials\\.json$",
		"service-account\\.json$",
		"secrets\\.yml$",
		"secrets\\.yaml$"
	],
	"capabilityRules": {
		"safe": [
			"read_file",
			"list_files",
			"search_files",
			"read_terminal_output",
			"ask_question",
			"execute_safe_command",
			"view_code",
			"view_diff"
		],
		"auto": [
			"read_file",
			"list_files",
			"search_files",
			"read_terminal_output",
			"ask_question",
			"execute_safe_command",
			"view_code",
			"view_diff",
			"write_file",
			"apply_diff",
			"execute_command",
			"run_tests",
			"create_branch",
			"commit_changes"
		],
		"full_autonomous": [
			"read_file",
			"list_files",
			"search_files",
			"read_terminal_output",
			"ask_question",
			"execute_safe_command",
			"view_code",
			"view_diff",
			"write_file",
			"apply_diff",
			"execute_command",
			"run_tests",
