# SuperRoo
SUPERROO_PROJECT_ID=superroo2
SUPERROO_REPO_PATH=/workspace/superroo2
SUPERROO_ENABLE_OPENCLAW=false
SUPERROO_ENABLE_HERMES=false
SUPERROO_SAFE_MODE=true

