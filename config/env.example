# PostgreSQL / pgvector
DATABASE_URL=postgresql://superroo:superroo_password@localhost:5432/superroo
PGVECTOR_DIMENSIONS=768

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHEAP_TEXT_MODEL=qwen2.5:0.5b

# Cloud Models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
