#!/bin/sh
#
# Post-commit hook for automatic lesson extraction (superroo2 repo)
#
# This hook analyzes the commit and extracts lessons
# to be added to the SuperRoo intelligence layer.
# Uses Node.js for cross-platform compatibility.

# Only run if we're in the superroo2 directory
if [ ! -f "memory/lesson-index.jsonl" ]; then
  exit 0
fi

# Get commit info
COMMIT_SHA=$(git rev-parse HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_AUTHOR=$(git log -1 --pretty=%an)
FILES_CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD | tr '\n' ',')

# Check if commit looks like it might contain a lesson
if echo "$COMMIT_MSG" | grep -qiE "(fix|bug|lesson|learned|workaround|solution|issue|error|crash|race|leak|performance|optimize|refactor|breaking|breaking change)"; then
  echo ""
  echo "📝 Potential lesson detected in commit $COMMIT_SHA"
  echo "   Consider adding to memory/lessons-learned.md if this is a reusable insight."
  echo ""
fi

# Auto-extract lessons using the script (if available)
if [ -f "scripts/extract-lesson-from-commit.mjs" ]; then
  node scripts/extract-lesson-from-commit.mjs "$COMMIT_SHA" "$COMMIT_MSG" "$COMMIT_AUTHOR" "$FILES_CHANGED" &
fi

# Ollama summarization (graceful if Ollama offline)
if [ -f "scripts/ollama-summarize-lesson.mjs" ]; then
  node scripts/ollama-summarize-lesson.mjs --quiet --last-only &
fi

# Regenerate ACTIVE_WORK.md from global task registry
if [ -f "scripts/gen-active-work.mjs" ]; then
  node scripts/gen-active-work.mjs 2>/dev/null &
fi

exit 0
