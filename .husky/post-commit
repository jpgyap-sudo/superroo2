#!/usr/bin/env node
/**
 * Post-commit hook for automatic lesson extraction (superroo2 repo)
 *
 * Cross-platform Node.js version (works on Windows, macOS, Linux).
 *
 * This hook analyzes the commit and extracts lessons
 * to be added to the SuperRoo intelligence layer.
 */

import { execSync } from "child_process"
import { existsSync } from "fs"
import path from "path"
import { fileURLToPath } from "url"

const __dirname = path.dirname(fileURLToPath(import.meta.url))
const ROOT = path.resolve(__dirname, "..")

// ── Helpers ──

function exec(command) {
	try {
		return execSync(command, {
			cwd: ROOT,
			encoding: "utf-8",
			stdio: ["pipe", "pipe", "ignore"],
			timeout: 5000,
		}).trim()
	} catch {
		return ""
	}
}

// ── Main ──

function main() {
	// Only run if we're in the superroo2 directory (has memory/lesson-index.jsonl)
	const indexFile = path.join(ROOT, "memory", "lesson-index.jsonl")
	if (!existsSync(indexFile)) {
		process.exit(0)
	}

	// Get commit info
	const sha = exec("git rev-parse HEAD")
	const message = exec('git log -1 --pretty=%B')
	const author = exec('git log -1 --pretty=%an')
	const filesRaw = exec("git diff-tree --no-commit-id --name-only -r HEAD")
	const files = filesRaw.replace(/\n/g, ",")

	if (!sha) {
		process.exit(0)
	}

	// Check if commit looks like it might contain a lesson
	const indicators = [
		/fix(e[ds])?:?\s+/i,
		/bug:?:?\s+/i,
		/lesson:?:?\s+/i,
		/learned:?:?\s+/i,
		/workaround:?:?\s+/i,
		/solution:?:?\s+/i,
		/issue:?:?\s+/i,
		/error:?:?\s+/i,
		/crash:?:?\s+/i,
		/race[\s-]?condition:?:?\s+/i,
		/memory[\s-]?leak:?:?\s+/i,
		/performance:?:?\s+/i,
		/optimize:?:?\s+/i,
		/refactor:?:?\s+/i,
		/breaking[\s-]?change:?:?\s+/i,
	]

	const matched = indicators.filter((p) => p.test(message))
	if (matched.length > 0) {
		console.log("")
		console.log(`📝 Potential lesson detected in commit ${sha.slice(0, 8)}`)
		console.log("   Consider adding to memory/lessons-learned.md if this is a reusable insight.")
		console.log("")
	}

	// Auto-extract lessons using the script (if available)
	const extractScript = path.join(ROOT, "scripts", "extract-lesson-from-commit.mjs")
	if (existsSync(extractScript)) {
		try {
			const escapedMessage = message.replace(/"/g, '\\"')
			execSync(
				`node "${extractScript}" "${sha}" "${escapedMessage}" "${author}" "${files}"`,
				{
					cwd: ROOT,
					encoding: "utf-8",
					stdio: "ignore",
					timeout: 15000,
				},
			)
		} catch {
			// Silently fail — hook should never block git commit
		}
	}
}

main()
